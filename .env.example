# По умолчанию всё работает БЕЗ ключей (llm_provider=fallback, vector_store=memory).
# Раскомментируйте нужный блок.

# --- Вариант 1: OpenAI-совместимый API (OpenAI / Ollama / vLLM / LM Studio) ---
# RAG_LLM_PROVIDER=openai
# RAG_LLM_BASE_URL=http://localhost:11434/v1   # пример: локальный Ollama
# RAG_LLM_API_KEY=ollama
# RAG_LLM_MODEL=qwen2.5

# --- Вариант 2: локальная модель через transformers (на RTX 4090) ---
# RAG_LLM_PROVIDER=local
# RAG_LOCAL_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# --- Вариант 3: GigaChat (OAuth) ---
# RAG_LLM_PROVIDER=gigachat
# RAG_GIGACHAT_AUTH_KEY=               # Authorization key (Base64) из личного кабинета
# RAG_GIGACHAT_SCOPE=GIGACHAT_API_PERS
# RAG_GIGACHAT_VERIFY_SSL=true         # false, если нет цепочки сертификатов Минцифры

# --- Реранк (мультиязычный кросс-энкодер) ---
# RAG_USE_RERANK=true

# --- Векторное хранилище Qdrant ---
# RAG_VECTOR_STORE=qdrant
# RAG_QDRANT_URL=http://localhost:6333

# --- Безопасность: карантин промпт-инъекций + контроль выхода ---
# RAG_ENABLE_SECURITY_GUARD=true
